# Copy this to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/deliverycompare"

# Secret for cron endpoint authentication (also used by /api/credentials)
CRON_SECRET="generate-a-random-string-here"

# App URL (used for internal API calls from server components)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Credential Capture ────────────────────────────────────────────────────────
# You do NOT need to set these manually.
# Run "npm run capture" to open a real browser, browse each platform,
# and have credentials saved to the database automatically.
#
# If you prefer to inject manually (e.g. from mitmproxy), use:
#   curl -X POST http://localhost:3000/api/credentials \
#     -H "Authorization: Bearer $CRON_SECRET" \
#     -H "Content-Type: application/json" \
#     -d '{"platform":"TALABAT","credentials":{"authorization":"Bearer xxx","cookie":"..."}}'
